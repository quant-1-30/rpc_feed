<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns
         http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
    
    <!-- 定义属性键 -->
    <key id="type" for="node" attr.name="type" attr.type="string"/>
    <key id="description" for="node" attr.name="description" attr.type="string"/>
    <key id="priority" for="node" attr.name="priority" attr.type="int"/>
    <key id="enabled" for="node" attr.name="enabled" attr.type="boolean"/>

    <!-- 配置属性 -->
    <key id="params" for="node" attr.name="params" attr.type="string"/>
    <key id="version" for="node" attr.name="version" attr.type="string"/>

    <graph id="G" edgedefault="directed">
        <node id="TextLoader">
            <data key="type">text</data>
            <data key="description">Unpacks data from binary format</data>
            <data key="priority">1</data>
            <data key="enabled">true</data>
            
            <!-- 业务属性 -->
            <data key="params">{"rename": {"日期": "datetime", "代码": "sid" ,"开盘价": "open", "最高价": "high", "最低价": "low", "收盘价": "close", "成交量（手）": "volume", "成交额（元）": "amount"}}</data>
            <data key="version">2.1.0</data>
        </node>
        <node id="UniverseDateParser">
            <data key="type">date</data>
            <data key="description">Parses date</data>
            <data key="priority">1</data>
            <data key="enabled">true</data>
            
            <!-- 业务属性 -->
            <data key="params">{"parser_col": "datetime", "format": "%Y-%m-%d %H:%M:%S"}</data>
            <data key="version">2.1.0</data>
        </node>
        <node id="Multiply">
            <data key="type">multiplier</data>
            <data key="description">Multiplies data</data>
            <data key="priority">1</data>
            <data key="enabled">true</data>
            
            <!-- 业务属性 -->
            <data key="params">{"multiply": {"open": 100000, "high": 100000, "low": 100000, "close": 100000, "volume": 1000, "amount": 1000}}</data>  
            <data key="version">2.1.0</data>
        </node>
        <node id="Dtypes">
            <data key="type">dtypes</data>
            <data key="description">Sets data types</data>
            <data key="priority">1</data>
            <data key="enabled">true</data>
            
            <!-- 业务属性 -->
            <data key="params">{}</data>
            <data key="version">2.1.0</data>
        </node>
        <node id="ParquetWriter">
            <data key="type">writer</data>
            <data key="description">Writes data to PostgreSQL</data>
            <data key="priority">2</data>
            <data key="enabled">true</data>
            
            <!-- 业务属性 -->
            <data key="params">{"root_path": "~/Downloads/quant/parquet/stock"}</data>
            <data key="version">2.1.0</data>
        </node>
        <edge source="TextLoader" target="UniverseDateParser"/>
        <edge source="UniverseDateParser" target="Multiply"/>
        <edge source="Multiply" target="Dtypes"/>
        <edge source="Dtypes" target="ParquetWriter"/>
    </graph>
</graphml>
